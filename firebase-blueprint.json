{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Staff member profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "doctor", "nurse", "receptionist", "pharmacist", "accountant"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "phoneNumber": { "type": "string" },
        "clinicId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status", "clinicId"]
    },
    "Patient": {
      "title": "Patient Record",
      "description": "Comprehensive patient demographic and insurance information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "idNumber": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "nextOfKin": { "type": "string" },
        "insuranceProvider": { "type": "string" },
        "insuranceNumber": { "type": "string" },
        "clinicId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "idNumber", "phoneNumber", "dateOfBirth", "gender", "clinicId"]
    },
    "Visit": {
      "title": "Patient Visit",
      "description": "Record of a single patient visit, including triage and encounter notes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "clinicId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "checked-in", "vitals", "history", "encounter", "billing", "completed", "no-show"] },
        "vitals": {
          "type": "object",
          "properties": {
            "bp": { "type": "string" },
            "pulse": { "type": "number" },
            "temp": { "type": "number" },
            "weight": { "type": "number" },
            "height": { "type": "number" },
            "spo2": { "type": "number" },
            "painScore": { "type": "number" },
            "recordedBy": { "type": "string" },
            "recordedAt": { "type": "string", "format": "date-time" }
          }
        },
        "history": {
          "type": "object",
          "properties": {
            "chiefComplaint": { "type": "string" },
            "hpi": { "type": "string" },
            "pmh": { "type": "string" },
            "socialHistory": { "type": "string" },
            "familyHistory": { "type": "string" },
            "recordedBy": { "type": "string" },
            "recordedAt": { "type": "string", "format": "date-time" }
          }
        },
        "encounter": {
          "type": "object",
          "properties": {
            "examination": { "type": "string" },
            "diagnosis": { "type": "string" },
            "plan": { "type": "string" },
            "doctorId": { "type": "string" },
            "recordedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["patientId", "date", "status", "clinicId"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Drugs, equipment, and other clinic supplies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "genericName": { "type": "string" },
        "strength": { "type": "string" },
        "form": { "type": "string" },
        "batchNumber": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "stockQuantity": { "type": "number" },
        "reorderLevel": { "type": "number" },
        "supplier": { "type": "string" },
        "type": { "type": "string", "enum": ["drug", "equipment", "other"] },
        "buyingPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "unit": { "type": "string" },
        "clinicId": { "type": "string" }
      },
      "required": ["name", "stockQuantity", "type", "clinicId"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Medication prescribed during a visit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "visitId": { "type": "string" },
        "patientId": { "type": "string" },
        "clinicId": { "type": "string" },
        "drugId": { "type": "string" },
        "drugName": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "duration": { "type": "string" },
        "instructions": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalCost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "dispensed", "cancelled"] },
        "prescribedBy": { "type": "string" },
        "prescribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["visitId", "patientId", "drugId", "quantity", "status", "clinicId"]
    },
    "Invoice": {
      "title": "Billing Invoice",
      "description": "Invoice for services and drugs provided.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "visitId": { "type": "string" },
        "clinicId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["unpaid", "partially-paid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "visitId", "total", "status", "clinicId"]
    },
    "Payment": {
      "title": "Payment Record",
      "description": "Record of payment received.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceId": { "type": "string" },
        "clinicId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["cash", "mpesa", "card", "insurance"] },
        "reference": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceId", "amount", "method", "date", "clinicId"]
    },
    "Utility": {
      "title": "Utility Bill",
      "description": "Monthly utility bill tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["electricity", "water", "internet", "rent", "other"] },
        "amount": { "type": "number" },
        "clinicId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["unpaid", "paid"] },
        "notes": { "type": "string" }
      },
      "required": ["type", "amount", "dueDate", "status", "clinicId"]
    },
    "Attendance": {
      "title": "Staff Attendance",
      "description": "Staff clock-in/out records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "clinicId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "clockIn": { "type": "string", "format": "date-time" },
        "clockOut": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date", "clockIn", "clinicId"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "Staff user profiles" },
    "/patients/{patientId}": { "schema": "Patient", "description": "Patient records" },
    "/visits/{visitId}": { "schema": "Visit", "description": "Patient visit records" },
    "/inventory/{itemId}": { "schema": "InventoryItem", "description": "Clinic inventory" },
    "/prescriptions/{prescriptionId}": { "schema": "Prescription", "description": "Medication prescriptions" },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Billing invoices" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records" },
    "/audit_logs/{logId}": { "schema": "object", "description": "Activity audit logs" },
    "/utilities/{utilityId}": { "schema": "Utility", "description": "Utility bills" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Staff attendance logs" }
  }
}
